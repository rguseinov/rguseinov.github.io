@article{guseinov2025armenia,
  title   = {Protests in {Armenia} in 2024},
  author  = {Guseinov, Ruslan},
  journal = {Istoriya i sovremennost' [History and Modernity]},
  year    = {2025},
  volume  = {56},
  number  = {2},
  pages   = {84--95},
  doi     = {10.30884/iis/2025.02.05},
  abstract = {The article analyses quasi-revolutionary protests in
    Armenia in April--June 2024. The analysis outlines the main
    cause of the protests -- the factor that is polymogenic, induced
    by Armenia's military defeat by Azerbaijan in 2023, which led to
    Azerbaijan establishing a full political and military control
    over Nagorno-Karabakh. The article describes the historical and
    political background of these protests within a particular
    revolutionary epoch, as well as a chronological account of the
    main events. Despite Pashinyan's resignation demands, this
    episode should be called a quasi-revolutionary one as the
    opposition failed to make sufficient efforts for a revolutionary
    siege of government.},
  keywords = {quasi-revolutionary episode, protests, Armenia,
    Pashinyan, Galstanyan, Nagorno-Karabakh, Tavush region,
    Azerbaijan},
  preview  = {guseinov2025armenia.png},
  pdf      = {https://www.socionauki.ru/upload/socionauki.ru/journal/iis/2025_2/05_Гусейнов_(84-95)_24-10-2025_10-14.pdf},
}

@incollection{guseinov2021caucasus,
  title     = {Revolutionary and Quasi-Revolutionary Episodes
               in {South Caucasus} 2020--2021},
  author    = {Guseinov, Ruslan},
  booktitle = {Sistemnyj monitoring global'nykh i regional'nykh
               riskov [Systemic Monitoring of Global and
               Regional Risks]},
  editor    = {Grinin, Leonid and Korotayev, Andrey
               and Bykanova, D. A.},
  volume    = {12},
  pages     = {603--614},
  year      = {2021},
  publisher = {Uchitel'},
  address   = {Volgograd},
  isbn      = {978-5-7057-6066-4},
  abstract  = {The article provides a characterisation of revolutionary events in the South Caucasus in 2020 and 2021. Revolutionary destabilisation affected two countries in the region — Armenia (2020–2021) and Georgia (2020). The analysis demonstrates that these events differ markedly in terms of duration, the intentions of the protesters, the balance of political forces, and the underlying causes that triggered instability in each country and in the region as a whole. In Armenia, for instance, opposition political forces — despite their fragmentation — explicitly pursued the goal of overthrowing the Pashinyan regime, which accounted for the prolonged and intense character of the protests. In Georgia, by contrast, the opposition did not seek to change power through unconstitutional means and advanced different demands. It is important to note, however, that both countries have maintained domestic political instability since the very proclamation of their independence. Although the protests in both countries had subsided by the time of writing, Armenia and Georgia remain the most acutely unstable states in the South Caucasus. Sonnet 4.6Extended},
  preview   = {guseinov2021caucasus.png},
}


